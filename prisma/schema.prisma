generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  name          String?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts       Account[]
  sessions       Session[]
  servers        Server[]
  statusPages    StatusPage[]
  notifications  NotificationChannel[]
  dailyReports   DailyReport[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

enum ServerStatus {
  ACTIVE
  PAUSED
  ARCHIVED
}

model Server {
  id                String        @id @default(cuid())
  userId            String        @map("user_id")
  name              String
  url               String
  intervalMinutes   Int           @default(5) @map("interval_minutes")
  status            ServerStatus  @default(ACTIVE)
  successKeywords   String[]      @default([]) @map("success_keywords")
  expectedStatus    Int           @default(200) @map("expected_status")
  timeoutMs         Int           @default(30000) @map("timeout_ms")
  followRedirects   Boolean       @default(true) @map("follow_redirects")
  headers           Json?         @default("{}")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")

  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  pings           PingLog[]
  incidents       Incident[]
  notifications   NotificationChannel[]

  @@index([userId, status])
  @@index([status, intervalMinutes])
  @@map("servers")
}

model PingLog {
  id          String   @id @default(cuid())
  serverId    String   @map("server_id")
  statusCode  Int?     @map("status_code")
  responseTimeMs Int   @map("response_time_ms")
  success     Boolean
  keywordMatch Boolean @default(true) @map("keyword_match")
  errorMessage String? @map("error_message")
  responseBody String? @db.Text @map("response_body")
  pingedAt    DateTime @default(now()) @map("pinged_at")
  region      String   @default("us-east-1")

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, pingedAt])
  @@index([pingedAt])
  @@map("ping_logs")
}

enum IncidentStatus {
  OPEN
  RESOLVED
  ACKNOWLEDGED
}

model Incident {
  id          String         @id @default(cuid())
  serverId    String         @map("server_id")
  status      IncidentStatus @default(OPEN)
  startedAt   DateTime       @default(now()) @map("started_at")
  resolvedAt  DateTime?      @map("resolved_at")
  message     String?
  notified    Boolean        @default(false)

  server Server @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([serverId, status])
  @@map("incidents")
}

enum ChannelType {
  WEBHOOK
  DISCORD
  SLACK
  TELEGRAM
  EMAIL
}

model NotificationChannel {
  id        String      @id @default(cuid())
  userId    String      @map("user_id")
  serverId  String?     @map("server_id")
  type      ChannelType
  label     String
  config    Json        @default("{}")
  isGlobal  Boolean     @default(false) @map("is_global")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  server Server? @relation(fields: [serverId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([serverId])
  @@map("notification_channels")
}

model StatusPage {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  slug        String   @unique
  title       String
  description String?
  branding    Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("status_pages")
}

model DailyReport {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  date        DateTime @default(now()) @db.Date
  totalUptime Float    @map("total_uptime")
  serversUp   Int      @map("servers_up")
  serversDown Int      @map("servers_down")
  avgLatency  Float    @map("avg_latency")
  data        Json     @default("{}")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("daily_reports")
}
